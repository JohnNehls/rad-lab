## uncoded example ##
	bandwidth:
	PW=1.2e+00 f_start=-6.1e-01 f_end=6.1e-01
	xcor:
	PW=1.0 f_start=-0.5 f_end=0.5
	PW_av=1.1 f_start_av=-0.5 f_end_av=0.5
## Barker example ##
	bandwidth:
	PW=1.2e+00 f_start=-6.1e-01 f_end=6.1e-01
	xcor:
	PW=1.0 f_start=-0.5 f_end=0.5
	PW_av=1.1 f_start_av=-0.5 f_end_av=0.5
## random code example  ##
	bandwidth:
	PW=8.8e-01 f_start=-4.4e-01 f_end=4.4e-01
	xcor:
	PW=1.0 f_start=-0.5 f_end=0.5
	PW_av=1.1 f_start_av=-0.5 f_end_av=0.5
## LFM example ##
	bandwidth:
	PW=6.7e-01 f_start=-3.6e-01 f_end=3.1e-01
	xcor:
	PW=1.3 f_start=-0.6 f_end=0.6
	PW_av=1.3 f_start_av=-0.7 f_end_av=0.7
